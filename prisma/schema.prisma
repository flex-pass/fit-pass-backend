// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  GYM_OWNER
  ADMIN
  SUPERADMIN
}

enum PlanType {
  BASIC
  STANDARD
  PREMIUM
  CORPORATE_BASIC
  NONE
}

enum CheckInStatus {
  SUCCESS
  FAILED
  FRAUD
}

model User {
  id               String              @id @default(uuid())
  phone_number     String?             @unique
  email            String              @unique
  password         String
  name             String
  city             String?
  credits_balance  Int                 @default(0)
  plan_type        PlanType            @default(NONE)
  plan_expiry_date DateTime?
  role             Role                @default(USER)
  is_active        Boolean             @default(true)
  corporate_id     String?
  corporate        Corporate?          @relation(fields: [corporate_id], references: [id])
  gyms             Gym[]
  check_ins        CheckIn[]
  transactions     CreditTransaction[]
  created_at       DateTime            @default(now())
  updated_at       DateTime            @updatedAt
}

model Gym {
  id                   String     @id @default(uuid())
  name                 String
  owner_user_id        String
  owner                User       @relation(fields: [owner_user_id], references: [id])
  address              String
  latitude             Decimal    @db.Decimal(10, 8)
  longitude            Decimal    @db.Decimal(11, 8)
  tier                 Int        // 1 = Premium, 2 = Mid, 3 = Budget, 4 = Boutique Studio
  peak_credit_cost     Int
  offpeak_credit_cost  Int
  peak_start_morning   String     // e.g. "06:00"
  peak_end_morning     String     // e.g. "09:00"
  peak_start_evening   String     // e.g. "18:00"
  peak_end_evening     String     // e.g. "21:00"
  payout_per_credit    Decimal    @db.Decimal(10, 2)
  kill_switch          Boolean    @default(false)
  is_approved          Boolean    @default(false)
  monthly_guarantee    Decimal    @default(0) @db.Decimal(10, 2)
  check_ins            CheckIn[]
  created_at           DateTime   @default(now())
  updated_at           DateTime   @updatedAt
}

model CheckIn {
  id                 String        @id @default(uuid())
  user_id            String
  user               User          @relation(fields: [user_id], references: [id])
  gym_id             String
  gym                Gym           @relation(fields: [gym_id], references: [id])
  checked_in_at      DateTime      @default(now())
  credits_used       Int
  gym_payout_amount  Decimal       @db.Decimal(10, 2)
  user_lat           Decimal       @db.Decimal(10, 8)
  user_lng           Decimal       @db.Decimal(11, 8)
  qr_token           String        @db.VarChar(500)
  status             CheckInStatus
}

model Corporate {
  id         String   @id @default(uuid())
  name       String
  domain     String   @unique
  employees  User[]
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model CreditTransaction {
  id          String   @id @default(uuid())
  user_id     String
  user        User     @relation(fields: [user_id], references: [id])
  amount      Int
  type        String   // 'signup_bonus', 'topup', 'monthly_reset', 'visit_deduction', 'refund'
  description String?
  created_at  DateTime @default(now())
}
